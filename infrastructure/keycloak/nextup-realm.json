{
  "realm": "nextup",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 900,
  "roles": {
    "realm": [
      { "name": "player", "description": "Can register for runs and manage own registrations." },
      { "name": "organizer", "description": "Can manage own gyms, courts and runs." },
      { "name": "admin", "description": "Full administrative access (override ownership)." }
    ]
  },
  "clients": [
    {
      "clientId": "nextup-web",
      "name": "NextUp Web (SPA)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "rootUrl": "https://nextup.local",
      "baseUrl": "https://nextup.local",
      "redirectUris": ["https://nextup.local/*"],
      "webOrigins": ["https://nextup.local"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "https://nextup.local/*"
      },
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "nextup-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "nextup-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "nextup-api",
      "name": "NextUp API (resource server)",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    }
  ],
  "users": [
    {
      "id": "33333333-3333-3333-3333-333333333333",
      "username": "player1",
      "email": "player1@nextup.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Penny",
      "lastName": "Player",
      "credentials": [
        { "type": "password", "value": "player1pass", "temporary": false }
      ],
      "realmRoles": ["player"]
    },
    {
      "id": "44444444-4444-4444-4444-444444444444",
