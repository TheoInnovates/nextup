# NextUp — base Caddy config.
# Per-service routing is label-driven (caddy-docker-proxy); see service `caddy.*`
# labels in docker-compose.yml. This file holds only global config + the shared
# TLS snippet that each site imports.

{
	# Metrics endpoint for Prometheus to scrape in Phase 8.
	servers {
		metrics
	}
}

# Imported by every site via `caddy.import: tls_certs`. Local dev uses mkcert
# certs generated by scripts/setup.sh into infrastructure/caddy/certs/.
(tls_certs) {
	tls /certs/cert.pem /certs/key.pem
}
