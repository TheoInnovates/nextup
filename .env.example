# =============================================================================
# NextUp — example environment configuration
# Copy to `.env` (gitignored) and adjust. NEVER commit real secrets.
# Placeholders prefixed CHANGE_ME_ must be replaced for any non-throwaway use.
# All application timestamps are stored in UTC; display uses the gym timezone.
# =============================================================================

# --- Domain / hosts (label-driven Caddy + mkcert *.local TLS) ----------------
DOMAIN_SUFFIX=local
WEB_HOST=nextup.local
API_HOST=api.nextup.local
AUTH_HOST=auth.nextup.local
MAIL_HOST=mail.nextup.local
GRAFANA_HOST=grafana.nextup.local
PROMETHEUS_HOST=prometheus.nextup.local

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=nextup
POSTGRES_PASSWORD=CHANGE_ME_postgres
POSTGRES_DB=nextup
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis -------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --- Keycloak (admin + realm) ------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin
KC_DB=postgres
KC_HOSTNAME=auth.nextup.local
KEYCLOAK_REALM=nextup
# Public SPA client (Authorization Code + PKCE, no secret in browser)
KEYCLOAK_WEB_CLIENT_ID=nextup-web
# API audience / resource client validated by the backend
KEYCLOAK_API_CLIENT_ID=nextup-api

# --- Backend (FastAPI) -------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://nextup:CHANGE_ME_postgres@postgres:5432/nextup
REDIS_URL=redis://redis:6379/0
# OIDC issuer must match the `iss` claim in tokens (public host, via Caddy).
OIDC_ISSUER=https://auth.nextup.local/realms/nextup
OIDC_AUDIENCE=nextup-api
# JWKS is fetched server-side over the internal Docker network (no public DNS /
# mkcert CA needed inside the container). Keys are matched to `iss` independently.
JWKS_URL=http://keycloak:8080/realms/nextup/protocol/openid-connect/certs
CORS_ORIGINS=https://nextup.local
LOG_LEVEL=INFO
APP_ENV=local

# --- Web (Next.js) -----------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.nextup.local/api/v1
NEXT_PUBLIC_OIDC_ISSUER=https://auth.nextup.local/realms/nextup
NEXT_PUBLIC_OIDC_CLIENT_ID=nextup-web

# --- Celery ------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Mailpit (local email capture) -------------------------------------------
SMTP_HOST=mailpit
SMTP_PORT=1025

# --- Grafana -----------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana
